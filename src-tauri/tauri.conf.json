{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Duet Desktop Weather",
  "version": "0.1.0",
  "identifier": "com.duet.desktopweather",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Duet Desktop Weather",
        "minWidth": 1,
        "minHeight": 1,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnBottom": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "useLocalToolsDir": true,
    "resources": [
      "../app-config.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
